generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
}

model User {
  id             String         @id @default(uuid()) @db.Char(36)
  email          String         @unique @db.VarChar(255)
  name           String         @db.VarChar(255)
  passwordHash   String?        @map("password_hash") @db.VarChar(255)
  googleId       String?        @map("google_id") @db.VarChar(255)
  avatarUrl      String?        @map("avatar_url") @db.VarChar(500)
  createdAt      DateTime       @default(now()) @map("created_at")
  updatedAt      DateTime       @updatedAt @map("updated_at")

  refreshTokens  RefreshToken[]
  gmailToken     GmailToken?
  categories     Category[]
  transactions   Transaction[]
  emailLogs      EmailLog[]

  @@map("users")
}

model RefreshToken {
  id          String   @id @default(uuid()) @db.Char(36)
  userId      String   @map("user_id") @db.Char(36)
  tokenHash   String   @map("token_hash") @db.VarChar(255)
  expiresAt   DateTime @map("expires_at")
  isRevoked   Boolean  @default(false) @map("is_revoked")
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model GmailToken {
  id                    String    @id @default(uuid()) @db.Char(36)
  userId                String    @unique @map("user_id") @db.Char(36)
  accessTokenEncrypted  String    @map("access_token_encrypted") @db.Text
  refreshTokenEncrypted String    @map("refresh_token_encrypted") @db.Text
  tokenExpiresAt        DateTime  @map("token_expires_at")
  gmailWatchExpiry      DateTime? @map("gmail_watch_expiry")
  historyId             String?   @map("history_id") @db.VarChar(50)
  lastSyncedAt          DateTime? @map("last_synced_at")
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("gmail_tokens")
}

model Category {
  id              String   @id @default(uuid()) @db.Char(36)
  userId          String   @map("user_id") @db.Char(36)
  name            String   @db.VarChar(100)
  icon            String?  @db.VarChar(50)
  color           String?  @db.VarChar(7)
  transactionType String   @map("transaction_type") @db.VarChar(20)
  isDefault       Boolean  @default(false) @map("is_default")
  createdAt       DateTime @default(now()) @map("created_at")

  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions    Transaction[]

  @@map("categories")
}

model Transaction {
  id              String   @id @default(uuid()) @db.Char(36)
  userId          String   @map("user_id") @db.Char(36)
  categoryId      String?  @map("category_id") @db.Char(36)
  amount          Decimal  @db.Decimal(15, 2)
  transactionType String   @map("transaction_type") @db.VarChar(20)
  merchant        String?  @db.VarChar(255)
  bankSource      String?  @map("bank_source") @db.VarChar(50)
  note            String?  @db.VarChar(500)
  source          String   @db.VarChar(20)
  parseStatus     String?  @map("parse_status") @db.VarChar(20)
  transactedAt    DateTime @map("transacted_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  category        Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  emailLogs       EmailLog[]

  @@map("transactions")
}

model EmailLog {
  id              String   @id @default(uuid()) @db.Char(36)
  transactionId   String?  @map("transaction_id") @db.Char(36)
  userId          String   @map("user_id") @db.Char(36)
  gmailMessageId  String   @unique @map("gmail_message_id") @db.VarChar(255)
  senderEmail     String   @map("sender_email") @db.VarChar(255)
  subject         String   @db.VarChar(500)
  parseStatus     String   @map("parse_status") @db.VarChar(20)
  failureReason   String?  @map("failure_reason") @db.VarChar(500)
  receivedAt      DateTime @map("received_at")
  processedAt     DateTime? @map("processed_at")

  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transaction     Transaction? @relation(fields: [transactionId], references: [id], onDelete: SetNull)

  @@map("email_logs")
}
