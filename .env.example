# Database
# For Render/TiDB, use the full connection string
# Examples:
# mysql://user:password@host:port/database
# postgresql://user:password@host:port/database
DATABASE_URL="mysql://root:password@127.0.0.1:3306/catatuang"

# JWT Config
JWT_SECRET="generate-a-long-random-string"
JWT_EXPIRES_IN="15m"
JWT_REFRESH_SECRET="generate-another-long-random-string"
JWT_REFRESH_EXPIRES_IN="7d"

# Server Port
PORT=3000

# Google API Configuration
# Get these from Google Cloud Console
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your-client-secret"
# The callback URL MUST match your deployment URL in production
# Example: https://your-app.onrender.com/api/v1/auth/google/callback
GOOGLE_CALLBACK_URL="http://localhost:3000/api/v1/auth/google/callback"

# Gmail/PubSub Configuration
PUBSUB_TOPIC_NAME="projects/your-project-id/topics/your-topic-name"
GMAIL_WEBHOOK_SECRET="generate-a-secure-random-token"
GMAIL_WEBHOOK_AUDIENCE="https://your-public-backend-url/api/v1/gmail/webhook"

# AI Configuration
GEMINI_API_KEY="your-gemini-api-key"
